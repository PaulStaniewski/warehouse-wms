DJANGO_DEBUG=False
DJANGO_SECRET_KEY=replace-with-a-long-random-secret-at-least-50-characters-before-deploy
DJANGO_ALLOWED_HOSTS=wms.example.com
CORS_ALLOWED_ORIGINS=
CSRF_TRUSTED_ORIGINS=https://wms.example.com
DJANGO_ENABLE_API_DOCS=False
DJANGO_LOGIN_THROTTLE_RATE=5/minute

DJANGO_SESSION_COOKIE_SECURE=True
DJANGO_CSRF_COOKIE_SECURE=True
DJANGO_CSRF_COOKIE_HTTPONLY=False
DJANGO_SESSION_COOKIE_SAMESITE=Lax
DJANGO_CSRF_COOKIE_SAMESITE=Lax

DJANGO_USE_X_FORWARDED_PROTO=True
DJANGO_USE_X_FORWARDED_HOST=False
DJANGO_SECURE_SSL_REDIRECT=False
DJANGO_SECURE_HSTS_SECONDS=0
DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=False
DJANGO_SECURE_HSTS_PRELOAD=False

POSTGRES_DB=warehouse_wms
POSTGRES_USER=warehouse_wms
POSTGRES_PASSWORD=replace-with-a-strong-database-password
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_CONN_MAX_AGE=60
POSTGRES_CONNECT_TIMEOUT=5

REDIS_URL=redis://redis:6379/0
DJANGO_READINESS_CHECK_REDIS=False

GUNICORN_WORKERS=3
GUNICORN_TIMEOUT=60
